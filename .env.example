# Copy this to .env.local and fill in your values

# PostgreSQL connection string (required for Prisma)
# Example: postgresql://user:password@localhost:5432/most_likely_to
DATABASE_URL="postgresql://postgres:password@localhost:5432/most_likely_to"

# Socket.io URL - leave empty for same-origin (local dev)
# For production, set to your deployed URL: https://yourapp.railway.app
NEXT_PUBLIC_SOCKET_URL=""
